{
    "version": 2,
    "buildCommand": "pnpm --filter @workspace/mockup-sandbox run build && cp -r artifacts/mockup-sandbox/dist ./dist",
    "outputDirectory": "dist",
    "installCommand": "pnpm install --frozen-lockfile",
    "framework": null,
    "rewrites": [
      { "source": "/api/(.*)", "destination": "/api/index" }
    ]
  }
  